# ============================================================
# AI News Collector — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values if needed.
# APIキーは不要です。

# --- Collector settings ---
# How many hours back to look for articles (default: 24)
# FETCH_HOURS=24

# Max articles to collect per feed (default: 10)
# MAX_ARTICLES_PER_FEED=10

# HTTP request timeout in seconds (default: 15)
# REQUEST_TIMEOUT=15

# --- Output ---
# Directory where report files are saved (default: reports)
# OUTPUT_DIR=reports
